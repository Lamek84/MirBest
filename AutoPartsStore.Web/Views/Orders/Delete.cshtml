@model Order
@{
    ViewData["Title"] = "Bestellung löschen";
}
<h1>Bestellung #@Model.Id löschen?</h1>

<dl>
    <dt>Datum</dt>
    <dd>@Model.OrderDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
    <dt>Status</dt>
    <dd>@Model.Status</dd>
    <dt>Versandart</dt>
    <dd>@Model.DeliveryLabel</dd>
    <dt>Summe</dt>
    <dd>@Model.TotalAmount.ToString("N2") €</dd>
</dl>

<p class="text-danger">Dieser Vorgang kann nicht rückgängig gemacht werden. Bestand und Bonuspunkte werden dadurch nicht zurückgebucht.</p>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Löschen</button>
    <a asp-action="AdminIndex" class="btn btn-secondary">Abbrechen</a>
</form>
