@model Order
@{
    ViewData["Title"] = $"Bestellung #{Model.Id}";
}
<h1>Bestellung #@Model.Id</h1>

@if (TempData["OrderSuccess"] != null)
{
    if (Model.Status == OrderStatus.Paid)
    {
        <p class="alert-success">Vielen Dank! Deine Zahlung war erfolgreich, die Bestellung ist bestätigt.</p>
    }
    else
    {
        <p class="alert-success">Deine Bestellung wurde aufgegeben. Wir bestätigen die Zahlung in Kürze.</p>
    }
}

<p class="product-meta">Aufgegeben am @Model.OrderDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm") · Status: @Model.Status</p>

<table>
    <thead>
        <tr>
            <th>Bezeichnung</th>
            <th>Preis</th>
            <th>Menge</th>
            <th>Summe</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.ProductName</td>
            <td>@item.UnitPrice.ToString("N2") €</td>
            <td>@item.Quantity</td>
            <td>@((item.UnitPrice * item.Quantity).ToString("N2")) €</td>
        </tr>
    }
    </tbody>
</table>

@if (!string.IsNullOrEmpty(Model.DeliveryLabel))
{
    <p class="product-meta">Versandart: @Model.DeliveryLabel — @(Model.DeliveryCost == 0 ? "kostenlos" : Model.DeliveryCost.ToString("N2") + " €")</p>
}

@if (!string.IsNullOrEmpty(Model.ShippingStreet))
{
    <p class="product-meta">
        Lieferadresse: @Model.ShippingName<br />
        @Model.ShippingStreet<br />
        @Model.ShippingPostalCode @Model.ShippingCity
        @if (!string.IsNullOrEmpty(Model.ShippingPhone))
        {
            <br />
            <text>Tel.: @Model.ShippingPhone</text>
        }
    </p>
}

@if (Model.PointsRedeemed > 0)
{
    <p class="product-meta">Eingelöste Bonuspunkte: @Model.PointsRedeemed (−@Model.PointsDiscount.ToString("N2") €)</p>
}

<p class="cart-total">Gesamtsumme: @Model.TotalAmount.ToString("N2") €</p>

@if (Model.Status == OrderStatus.Paid && Model.PointsEarned > 0)
{
    <p class="product-meta">Für diese Bestellung gutgeschrieben: <strong>@Model.PointsEarned Bonuspunkte</strong></p>
}

<div class="cart-actions">
    <a asp-controller="Products" asp-action="Index" class="btn">Weiter einkaufen</a>
    <a asp-action="Index" class="btn btn-secondary">Zurück zu meinen Bestellungen</a>
</div>
