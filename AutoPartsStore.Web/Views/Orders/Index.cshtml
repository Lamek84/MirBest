@model IReadOnlyList<Order>
@{
    ViewData["Title"] = "Meine Bestellungen";
}
<h1>Meine Bestellungen</h1>

@if (!Model.Any())
{
    <p>Du hast noch keine Bestellungen aufgegeben.</p>
    <p><a asp-controller="Products" asp-action="Index" class="btn">Zum Katalog</a></p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Bestellnummer</th>
                <th>Datum</th>
                <th>Status</th>
                <th>Versandart</th>
                <th>Summe</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>#@order.Id</td>
                <td>@order.OrderDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                <td>@order.Status</td>
                <td>@order.DeliveryLabel</td>
                <td>@order.TotalAmount.ToString("N2") €</td>
                <td><a asp-action="Details" asp-route-id="@order.Id">Details</a></td>
            </tr>
        }
        </tbody>
    </table>
}
