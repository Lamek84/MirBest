@model IReadOnlyList<Category>
@{
    ViewData["Title"] = "Startseite";
    ViewData["Description"] = "MIRBEST in Bremen: Autoteile, KFZ-Werkstatt und professionelles Fahrzeug-Detailing. Hochwertige Ersatzteile, fachgerechte Reparaturen und Termine online buchen.";
}

<section class="services-section">
    <h2>Unsere Hauptdienstleistungen</h2>
    <div class="services-grid">
        <a class="service-card" asp-controller="Products" asp-action="Index">
            <img src="~/images/service-parts.png" alt="Autoteile" />
            <h3>Autoteile</h3>
            <p>Wir bieten hochwertige Autoteile und Zubehör, die perfekt zu den Bedürfnissen Ihres Fahrzeugs passen.</p>
        </a>
        <a class="service-card" asp-controller="Appointments" asp-action="Book">
            <img src="~/images/service-workshop.png" alt="KFZ Autowerkstatt" />
            <h3>KFZ Autowerkstatt</h3>
            <p>Unsere moderne KFZ-Werkstatt übernimmt fachgerechte Reparaturen, Wartung und Inspektionen für alle Fahrzeugtypen. Jetzt Termin vereinbaren.</p>
        </a>
        <a class="service-card" asp-controller="Detailing" asp-action="Index">
            <img src="~/images/service-detailing.png" alt="Detailing" />
            <h3>Detailing</h3>
            <p>Mit professionellem Fahrzeug-Detailing sorgen wir für eine gründliche Pflege und Aufbereitung bis ins kleinste Detail.</p>
        </a>
    </div>
</section>

<section class="catalog-section">
    <h2>Autoteile – unsere Kategorien</h2>

    @if (User.IsInRole("Admin"))
    {
        <p>
            <a asp-controller="Categories" asp-action="Index" class="btn">Kategorien verwalten</a>
            <a asp-controller="Appointments" asp-action="Index" class="btn btn-secondary">Terminanfragen verwalten</a>
            <a asp-controller="VehicleMakes" asp-action="Index" class="btn btn-secondary">Fahrzeugmarken verwalten</a>
            <a asp-controller="VehicleModels" asp-action="Index" class="btn btn-secondary">Fahrzeugmodelle verwalten</a>
            <a asp-controller="Customers" asp-action="Index" class="btn btn-secondary">Kunden verwalten</a>
            <a asp-controller="Legal" asp-action="Index" class="btn btn-secondary">Inhalte verwalten</a>
            <a asp-controller="Partners" asp-action="Index" class="btn btn-secondary">Partner verwalten</a>
        </p>
    }

    <div class="card-grid">
        @foreach (var category in Model)
        {
            <div class="category-card-wrapper">
                <a class="category-card" asp-controller="Products" asp-action="Index" asp-route-categoryId="@category.Id">
                    <img src="@(string.IsNullOrEmpty(category.ImageUrl) ? Url.Content("~/images/category-placeholder.png") : category.ImageUrl)" alt="@category.Name" />
                    <span>@category.Name</span>
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <p class="category-admin-actions">
                        <a asp-controller="Categories" asp-action="Edit" asp-route-id="@category.Id" class="icon-link" title="Bearbeiten">
                            <partial name="_Icon" model="@("edit")" />
                        </a>
                        <a asp-controller="Categories" asp-action="Delete" asp-route-id="@category.Id" class="icon-link" title="Löschen">
                            <partial name="_Icon" model="@("trash")" />
                        </a>
                    </p>
                }
            </div>
        }
    </div>
</section>

@{
    var partners = ViewBag.Partners as IReadOnlyList<Partner> ?? new List<Partner>();
}
@if (partners.Any())
{
    <section class="partners-section">
        <h2>Unsere Partner</h2>
        <div class="partners-row">
            @foreach (var partner in partners)
            {
                if (!string.IsNullOrEmpty(partner.LinkUrl))
                {
                    <a class="partner-card" href="@partner.LinkUrl" target="_blank" rel="noopener">
                        <img src="@partner.ImageUrl" alt="@partner.Name" />
                    </a>
                }
                else
                {
                    <div class="partner-card">
                        <img src="@partner.ImageUrl" alt="@partner.Name" />
                    </div>
                }
            }
        </div>
    </section>
}
