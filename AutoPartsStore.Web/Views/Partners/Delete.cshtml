@model Partner
@{
    ViewData["Title"] = "Partner löschen";
}
<h1>Partner löschen?</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<dl>
    <dt>Logo</dt>
    <dd><img src="@Model.ImageUrl" alt="@Model.Name" class="cart-thumb" /></dd>
    <dt>Name</dt>
    <dd>@Model.Name</dd>
    <dt>Link</dt>
    <dd>@(string.IsNullOrEmpty(Model.LinkUrl) ? "—" : Model.LinkUrl)</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Löschen</button>
    <a asp-action="Index" class="btn btn-secondary">Abbrechen</a>
</form>
