@{
    ViewData["Title"] = "Detailing-Paket hinzufügen";
}
<h1>Detailing-Paket hinzufügen</h1>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" class="form-control" required />
    </div>

    <div class="form-group">
        <label for="shortDescription">Kurzbeschreibung (auf der Übersichtskarte)</label>
        <input type="text" id="shortDescription" name="shortDescription" class="form-control" required />
    </div>

    <div class="form-group">
        <label for="displayOrder">Reihenfolge</label>
        <input type="number" id="displayOrder" name="displayOrder" class="form-control" value="0" />
    </div>

    <div class="form-group">
        <label for="image">Bild</label>
        <input type="file" id="image" name="image" class="form-control" accept=".png,.jpg,.jpeg,.svg,.webp" required />
        <small>PNG, JPG, SVG oder WEBP, maximal 5 MB.</small>
    </div>

    <div class="form-group">
        <label for="content">Ausführliche Beschreibung (HTML, auf der Detailseite)</label>
        <textarea id="content" name="content" class="form-control legal-editor" rows="20"></textarea>
    </div>

    <button type="submit" class="btn">Speichern</button>
    <a asp-action="Index" class="btn btn-secondary">Abbrechen</a>
</form>
