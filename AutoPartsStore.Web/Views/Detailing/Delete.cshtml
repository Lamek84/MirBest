@model DetailingPackage
@{
    ViewData["Title"] = "Detailing-Paket löschen";
}
<h1>Detailing-Paket löschen?</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<dl>
    <dt>Bild</dt>
    <dd><img src="@Model.ImageUrl" alt="@Model.Name" class="cart-thumb" /></dd>
    <dt>Name</dt>
    <dd>@Model.Name</dd>
    <dt>Kurzbeschreibung</dt>
    <dd>@Model.ShortDescription</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Löschen</button>
    <a asp-action="Index" class="btn btn-secondary">Abbrechen</a>
</form>
