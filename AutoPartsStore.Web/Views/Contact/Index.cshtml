@model ContactViewModel
@{
    ViewData["Title"] = "Kontakt";
}
<h1>Kontakt</h1>

<div class="contact-grid">
    <div class="contact-info">
        <h2>Kontaktinformationen</h2>
        @* Inhalt kommt aus der DB (LegalPage, Key "kontakt-info") — nur von Admins
           über /Legal/Edit/kontakt-info bearbeitbar, daher ist Html.Raw hier unkritisch. *@
        @Html.Raw(ViewBag.ContactInfoContent)
    </div>

    <div class="contact-form-wrapper">
        <h2>Schnelle Kontaktaufnahme</h2>

        @if (TempData["ContactSuccess"] != null)
        {
            <p class="alert-success">Vielen Dank für deine Nachricht! Wir melden uns bei dir.</p>
        }

        <form asp-controller="Contact" asp-action="Index" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Message">Nachricht</label>
                <textarea asp-for="Message" class="form-control" rows="6"></textarea>
            </div>

            <button type="submit" class="btn">Nachricht senden</button>
        </form>
    </div>
</div>
