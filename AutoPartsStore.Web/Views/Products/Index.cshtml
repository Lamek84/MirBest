@model IReadOnlyList<Product>
@{
    ViewData["Title"] = ViewData["CategoryName"] as string ?? "Ersatzteilkatalog";
    ViewData["Description"] = "Hochwertige Autoteile bei MIRBEST: Bremsen, Motor, Fahrwerk, Elektrik und mehr — schnelle Lieferung, faire Preise.";

    // Für "zurück zur Ausgangsseite" nach Create/Edit/Delete — inkl. aktueller
    // Filter (categoryId, Suche, Hersteller, Preisspanne).
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
    var currentCategoryId = ViewData["CurrentCategoryId"] as int?;
}
<h1>@(ViewData["CategoryName"] as string ?? "Ersatzteilkatalog")</h1>

<form asp-action="Index" method="get" class="filter-form">
    <input type="hidden" name="categoryId" value="@ViewData["CurrentCategoryId"]" />

    <div class="filter-field">
        <label for="search">Suche</label>
        <input type="text" id="search" name="search" value="@ViewData["CurrentSearch"]" placeholder="Name, Artikel- oder OEM-Nummer" class="form-control" />
    </div>

    <div class="filter-field">
        <label for="manufacturer">Hersteller</label>
        <select id="manufacturer" name="manufacturer" asp-items="ViewBag.Manufacturers" class="form-control">
            <option value="">Alle</option>
        </select>
    </div>

    <div class="filter-field filter-price-range">
        <div class="filter-price-item">
            <label for="minPrice">Preis von</label>
            <input type="number" id="minPrice" name="minPrice" value="@ViewData["CurrentMinPrice"]" step="0.01" min="0" class="form-control" />
        </div>
        <div class="filter-price-item">
            <label for="maxPrice">Preis bis</label>
            <input type="number" id="maxPrice" name="maxPrice" value="@ViewData["CurrentMaxPrice"]" step="0.01" min="0" class="form-control" />
        </div>
    </div>

    <div class="filter-actions">
        <button type="submit" class="btn">Filtern</button>
        <a asp-action="Index" asp-route-categoryId="@ViewData["CurrentCategoryId"]" class="btn btn-secondary">Zurücksetzen</a>
    </div>
</form>

@* VIN-Suche vorübergehend ausgeblendet — wird später fertig angebunden und wieder eingeblendet.
<form asp-action="Index" method="get" class="filter-form">
    <div class="filter-field">
        <label for="vin">Suche per VIN</label>
        <input type="text" id="vin" name="vin" value="@ViewData["CurrentVin"]" maxlength="17" placeholder="Fahrzeug-Identifizierungsnummer (17 Zeichen)" class="form-control" />
    </div>
    <div class="filter-actions">
        <button type="submit" class="btn">Per VIN suchen</button>
    </div>
</form>

@if (ViewData["VinVehicle"] != null)
{
    <p class="product-meta">Erkanntes Fahrzeug: <strong>@ViewData["VinVehicle"]</strong></p>
}
@if (ViewData["VinMessage"] != null)
{
    <p class="text-danger">@ViewData["VinMessage"]</p>
}
*@

@if (User.IsInRole("Admin"))
{
    <p>
        @if (currentCategoryId.HasValue)
        {
            <a asp-controller="Categories" asp-action="Create" asp-route-parentId="@currentCategoryId" asp-route-returnUrl="@currentUrl" class="btn btn-secondary">Unterkategorie hinzufügen</a>
        }
        <a asp-action="Create" asp-route-categoryId="@currentCategoryId" asp-route-returnUrl="@currentUrl" class="btn">Neues Ersatzteil hinzufügen</a>
    </p>
}

@if (!Model.Any())
{
    <p>Keine Ersatzteile gefunden. Passe ggf. die Filter an.</p>
}
else
{
    <div class="product-grid">
        @foreach (var p in Model)
        {
            <div class="product-card">
                <a asp-action="Details" asp-route-id="@p.Id" class="product-card-link">
                    <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? Url.Content("~/images/category-placeholder.png") : p.ImageUrl)" alt="@p.Name" />
                    <h3>@p.Name</h3>
                    <p class="product-meta">Art.-Nr. @p.PartNumber · @p.Manufacturer</p>
                    <p class="product-price">@p.Price.ToString("N2") €</p>
                    <p class="product-meta">Bestand: @p.StockQuantity</p>
                </a>

                <form asp-controller="Cart" asp-action="Add" method="post" class="add-to-cart-form">
                    <input type="hidden" name="productId" value="@p.Id" />
                    <input type="number" name="quantity" value="1" min="1" class="qty-input" />
                    <button type="submit" class="btn icon-btn">
                        <partial name="_Icon" model="@("cart")" />
                        <span>In den Warenkorb</span>
                    </button>
                </form>

                @if (User.IsInRole("Admin"))
                {
                    <p>
                        <a asp-action="Edit" asp-route-id="@p.Id" asp-route-returnUrl="@currentUrl" class="icon-link" title="Bearbeiten">
                            <partial name="_Icon" model="@("edit")" />
                        </a>
                        <a asp-action="Delete" asp-route-id="@p.Id" asp-route-returnUrl="@currentUrl" class="icon-link" title="Löschen">
                            <partial name="_Icon" model="@("trash")" />
                        </a>
                    </p>
                }
            </div>
        }
    </div>
}
