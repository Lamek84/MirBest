@model ProductViewModel
@{
    ViewData["Title"] = "Ersatzteil bearbeiten";
}
<h1>Ersatzteil bearbeiten</h1>

@if (!string.IsNullOrEmpty(Model.ImageUrl))
{
    <div class="form-group">
        <label>Aktuelles Bild</label><br />
        <img src="@Model.ImageUrl" alt="@Model.Name" class="cart-thumb" />
    </div>
}

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImageUrl" />
    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description">Beschreibung</label>
        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Detaillierte Beschreibung für die Produktseite (optional)."></textarea>
    </div>

    <div class="form-group">
        <label asp-for="Sku">SKU (interne Artikelnummer)</label>
        <input asp-for="Sku" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="PartNumber">Herstellernummer</label>
        <input asp-for="PartNumber" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Manufacturer">Marke</label>
        <input asp-for="Manufacturer" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Price">Preis</label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="StockQuantity">Bestand</label>
        <input asp-for="StockQuantity" class="form-control" />
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CategoryId">Kategorie</label>
        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-control">
            <option value="">-- Kategorie wählen --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="image">Neues Bild (optional)</label>
        <input type="file" id="image" name="image" class="form-control" accept=".png,.jpg,.jpeg,.svg,.webp" />
        <small>Nur ausfüllen, um das bisherige Bild zu ersetzen. PNG, JPG, SVG oder WEBP, maximal 5 MB.</small>
    </div>

    <button type="submit" class="btn">Speichern</button>
    <a href="@(string.IsNullOrEmpty(ViewBag.ReturnUrl as string) ? Url.Action("Index") : ViewBag.ReturnUrl)" class="btn btn-secondary">Abbrechen</a>
</form>

<section class="fitment-section">
    <h2>Fahrzeug-Kompatibilität</h2>

    @if (TempData["FitmentError"] != null)
    {
        <p class="text-danger">@TempData["FitmentError"]</p>
    }

    @{
        var fitments = ViewBag.Fitments as IReadOnlyList<ProductVehicleFitment>;
    }

    @if (fitments is null || !fitments.Any())
    {
        <p class="product-meta">Noch keine passenden Fahrzeuge hinterlegt.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Marke</th>
                    <th>Modell</th>
                    <th>Baujahre</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var fitment in fitments)
            {
                <tr>
                    <td>@fitment.VehicleModel?.VehicleMake?.Name</td>
                    <td>@fitment.VehicleModel?.Name</td>
                    <td>
                        @if (fitment.YearFrom is null && fitment.YearTo is null)
                        {
                            <span>alle Baujahre</span>
                        }
                        else
                        {
                            <span>@(fitment.YearFrom?.ToString() ?? "…") – @(fitment.YearTo?.ToString() ?? "…")</span>
                        }
                    </td>
                    <td>
                        <form asp-action="RemoveFitment" method="post" class="inline-form">
                            <input type="hidden" name="id" value="@fitment.Id" />
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger icon-btn" title="Entfernen">
                                <partial name="_Icon" model="@("trash")" />
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <form asp-action="AddFitment" method="post" class="fitment-add-form">
        <input type="hidden" name="productId" value="@Model.Id" />

        <div class="form-group">
            <label>Fahrzeugmodell</label>
            <select name="vehicleModelId" asp-items="ViewBag.VehicleModelId" class="form-control">
                <option value="">-- Modell wählen --</option>
            </select>
        </div>

        <div class="form-group">
            <label>Baujahr von (optional)</label>
            <input type="number" name="yearFrom" class="form-control" min="1950" max="2100" placeholder="z. B. 2015" />
        </div>

        <div class="form-group">
            <label>Baujahr bis (optional)</label>
            <input type="number" name="yearTo" class="form-control" min="1950" max="2100" placeholder="z. B. 2020" />
        </div>

        <button type="submit" class="btn">Fahrzeug hinzufügen</button>
    </form>

    <p class="product-meta">Verfügbare Marken/Modelle fehlen? <a asp-controller="VehicleMakes" asp-action="Index">Marken verwalten</a> · <a asp-controller="VehicleModels" asp-action="Index">Modelle verwalten</a></p>
</section>

<section class="fitment-section">
    <h2>OEM- und Vergleichsnummern</h2>
    <p class="product-meta">Grundlage für die Teilesuche nach VIN und OEM-Nummer.</p>

    @if (TempData["ReferenceError"] != null)
    {
        <p class="text-danger">@TempData["ReferenceError"]</p>
    }

    @{
        var references = ViewBag.ReferenceNumbers as IReadOnlyList<ProductReferenceNumber>;
    }

    @if (references is null || !references.Any())
    {
        <p class="product-meta">Noch keine Nummern hinterlegt.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Typ</th>
                    <th>Nummer</th>
                    <th>Marke</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var reference in references)
            {
                <tr>
                    <td>@(reference.Type == ReferenceNumberType.Oem ? "OEM" : "Vergleich")</td>
                    <td>@reference.Number</td>
                    <td>@reference.Brand</td>
                    <td>
                        <form asp-action="RemoveReferenceNumber" method="post" class="inline-form">
                            <input type="hidden" name="id" value="@reference.Id" />
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger icon-btn" title="Entfernen">
                                <partial name="_Icon" model="@("trash")" />
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <form asp-action="AddReferenceNumber" method="post" class="fitment-add-form">
        <input type="hidden" name="productId" value="@Model.Id" />

        <div class="form-group">
            <label>Typ</label>
            <select name="type" class="form-control">
                <option value="@((int)ReferenceNumberType.Oem)">OEM-Nummer</option>
                <option value="@((int)ReferenceNumberType.Cross)">Vergleichsnummer</option>
            </select>
        </div>

        <div class="form-group">
            <label>Nummer</label>
            <input type="text" name="number" class="form-control" placeholder="z. B. 1K0 615 301 AA" />
        </div>

        <div class="form-group">
            <label>Marke (optional)</label>
            <input type="text" name="brand" class="form-control" placeholder="z. B. BOSCH" />
        </div>

        <button type="submit" class="btn">Nummer hinzufügen</button>
    </form>
</section>
