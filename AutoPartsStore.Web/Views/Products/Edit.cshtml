@model Product
@{
    ViewData["Title"] = "Ersatzteil bearbeiten";
}
<h1>Ersatzteil bearbeiten</h1>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PartNumber">Artikelnummer</label>
        <input asp-for="PartNumber" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Manufacturer">Hersteller</label>
        <input asp-for="Manufacturer" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Price">Preis</label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="StockQuantity">Bestand</label>
        <input asp-for="StockQuantity" class="form-control" />
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CategoryId">Kategorie</label>
        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-control">
            <option value="">-- Kategorie wählen --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ImageUrl">Bild-URL</label>
        <input asp-for="ImageUrl" class="form-control" placeholder="/images/products/beispiel.svg" />
    </div>

    <button type="submit" class="btn">Speichern</button>
    <a asp-action="Index" class="btn btn-secondary">Abbrechen</a>
</form>
