@model VehicleModel
@{
    ViewData["Title"] = "Modell hinzufügen";
}
<h1>Modell hinzufügen</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="VehicleMakeId">Marke</label>
        <select asp-for="VehicleMakeId" asp-items="ViewBag.VehicleMakeId" class="form-control">
            <option value="">-- Marke wählen --</option>
        </select>
        <span asp-validation-for="VehicleMakeId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Name">Modell</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <button type="submit" class="btn">Speichern</button>
    <a asp-action="Index" class="btn btn-secondary">Abbrechen</a>
</form>
