@model IReadOnlyList<Category>
@{
    ViewData["Title"] = "Kategorien verwalten";
}
<h1>Kategorien verwalten</h1>

<p><a asp-action="Create" class="btn">Neue Kategorie hinzufügen</a></p>

@if (!Model.Any())
{
    <p>Noch keine Kategorien vorhanden.</p>
}
else
{
    var parentNames = ViewBag.ParentNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    <table>
        <thead>
            <tr>
                <th></th>
                <th>Name</th>
                <th>Übergeordnete Kategorie</th>
                <th>Beschreibung</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.Count; i++)
        {
            var category = Model[i];
            // Innerhalb der (nach Elternteil gruppierten) Liste ermitteln, ob dies das
            // erste/letzte Geschwister ist — dann "Nach oben"/"Nach unten" deaktivieren.
            var isFirstSibling = i == 0 || Model[i - 1].ParentCategoryId != category.ParentCategoryId;
            var isLastSibling = i == Model.Count - 1 || Model[i + 1].ParentCategoryId != category.ParentCategoryId;
            <tr>
                <td><img src="@(string.IsNullOrEmpty(category.ImageUrl) ? Url.Content("~/images/category-placeholder.png") : category.ImageUrl)" alt="@category.Name" class="cart-thumb" /></td>
                <td>@category.Name</td>
                <td>@(category.ParentCategoryId.HasValue && parentNames.TryGetValue(category.ParentCategoryId.Value, out var parentName) ? parentName : "—")</td>
                <td>@category.Description</td>
                <td>
                    <form asp-action="MoveUp" asp-route-id="@category.Id" method="post" class="move-form">
                        <button type="submit" class="icon-link-btn" title="Nach oben" @(isFirstSibling ? "disabled" : "")>
                            <partial name="_Icon" model="@("arrow-up")" />
                        </button>
                    </form>
                    <form asp-action="MoveDown" asp-route-id="@category.Id" method="post" class="move-form">
                        <button type="submit" class="icon-link-btn" title="Nach unten" @(isLastSibling ? "disabled" : "")>
                            <partial name="_Icon" model="@("arrow-down")" />
                        </button>
                    </form>
                    <a asp-action="Edit" asp-route-id="@category.Id" class="icon-link" title="Bearbeiten">
                        <partial name="_Icon" model="@("edit")" />
                    </a>
                    <a asp-action="Delete" asp-route-id="@category.Id" class="icon-link" title="Löschen">
                        <partial name="_Icon" model="@("trash")" />
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
