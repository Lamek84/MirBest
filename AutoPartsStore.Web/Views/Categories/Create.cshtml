@model Category
@{
    ViewData["Title"] = "Kategorie hinzufügen";
}
<h1>Kategorie hinzufügen</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description">Beschreibung</label>
        <input asp-for="Description" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="ImageUrl">Bild-URL</label>
        <input asp-for="ImageUrl" class="form-control" placeholder="/images/categories/beispiel.svg" />
    </div>

    <button type="submit" class="btn">Speichern</button>
    <a asp-action="Index" class="btn btn-secondary">Abbrechen</a>
</form>
