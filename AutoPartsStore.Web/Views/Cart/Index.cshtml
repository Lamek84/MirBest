@model IReadOnlyList<CartItem>
@{
    ViewData["Title"] = "Warenkorb";
}
<h1>Warenkorb</h1>

@if (!Model.Any())
{
    <p>Dein Warenkorb ist leer.</p>
    <p><a asp-controller="Products" asp-action="Index" class="btn">Zum Katalog</a></p>
}
else
{
    var total = Model.Sum(i => i.Quantity * i.Product!.Price);
    int bonusPoints = ViewBag.BonusPoints ?? 0;

    <table>
        <thead>
            <tr>
                <th></th>
                <th>Bezeichnung</th>
                <th>Preis</th>
                <th>Menge</th>
                <th>Summe</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><img src="@item.Product!.ImageUrl" alt="@item.Product.Name" class="cart-thumb" /></td>
                <td>@item.Product.Name</td>
                <td>@item.Product.Price.ToString("N2") €</td>
                <td>
                    <form asp-action="UpdateQuantity" method="post" class="inline-form">
                        <input type="hidden" name="cartItemId" value="@item.Id" />
                        <input type="number" name="quantity" value="@item.Quantity" min="1" class="qty-input" />
                        <button type="submit" class="btn btn-secondary">Aktualisieren</button>
                    </form>
                </td>
                <td>@((item.Quantity * item.Product.Price).ToString("N2")) €</td>
                <td>
                    <form asp-action="Remove" method="post" class="inline-form">
                        <input type="hidden" name="cartItemId" value="@item.Id" />
                        <button type="submit" class="btn btn-danger icon-btn" title="Entfernen">
                            <partial name="_Icon" model="@("trash")" />
                        </button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <p class="cart-total">Zwischensumme: @total.ToString("N2") € <span class="product-meta">zzgl. Versandkosten je nach gewählter Versandart</span></p>

    @if (User.Identity!.IsAuthenticated)
    {
        <p class="product-meta">
            Deine Bonuspunkte: <strong>@bonusPoints</strong> (100 Punkte = 1 € Rabatt)
        </p>
    }

    <div class="cart-actions">
        <form asp-action="Checkout" method="post" class="checkout-form">
            <div class="delivery-options">
                <p class="delivery-title">Versandart wählen</p>
                @foreach (var option in DeliveryOptions.All)
                {
                    <label class="delivery-option">
                        @if (option.Code == DeliveryOptions.Pickup.Code)
                        {
                            <input type="radio" name="deliveryMethod" value="@option.Code" class="delivery-radio" data-pickup="true" checked />
                        }
                        else
                        {
                            <input type="radio" name="deliveryMethod" value="@option.Code" class="delivery-radio" data-pickup="false" />
                        }
                        <span>@option.DisplayName</span>
                        <span class="delivery-price">@(option.Price == 0 ? "kostenlos" : option.Price.ToString("N2") + " €")</span>
                    </label>
                }
            </div>

            <div class="shipping-address-fields" id="shippingAddressFields" style="display:none;">
                <p class="delivery-title">Lieferadresse</p>
                <div class="filter-field">
                    <label for="shippingName">Name des Empfängers</label>
                    <input type="text" id="shippingName" name="shippingName" class="form-control" />
                </div>
                <div class="filter-field">
                    <label for="shippingStreet">Straße und Hausnummer</label>
                    <input type="text" id="shippingStreet" name="shippingStreet" class="form-control" />
                </div>
                <div class="filter-field filter-price-range">
                    <div class="filter-price-item">
                        <label for="shippingPostalCode">PLZ</label>
                        <input type="text" id="shippingPostalCode" name="shippingPostalCode" class="form-control" />
                    </div>
                    <div class="filter-price-item">
                        <label for="shippingCity">Ort</label>
                        <input type="text" id="shippingCity" name="shippingCity" class="form-control" />
                    </div>
                </div>
                <div class="filter-field">
                    <label for="shippingPhone">Telefon (optional, für Rückfragen des Versanddienstleisters)</label>
                    <input type="tel" id="shippingPhone" name="shippingPhone" class="form-control" />
                </div>
            </div>

            @if (User.Identity!.IsAuthenticated && bonusPoints > 0)
            {
                <div class="filter-field">
                    <label for="pointsToRedeem">Bonuspunkte einlösen (max. @bonusPoints)</label>
                    <input type="number" id="pointsToRedeem" name="pointsToRedeem" value="0" min="0" max="@bonusPoints" step="1" class="form-control" />
                </div>
            }

            <button type="submit" class="btn">Jetzt bezahlen</button>
        </form>
        <a asp-controller="Products" asp-action="Index" class="btn btn-secondary">Weiter einkaufen</a>
    </div>
}

@section Scripts {
    <script src="~/js/cart-checkout.js"></script>
}
