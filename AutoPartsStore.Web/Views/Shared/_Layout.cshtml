@inject Microsoft.AspNetCore.Identity.SignInManager<AutoPartsStore.Data.Identity.ApplicationUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<AutoPartsStore.Data.Identity.ApplicationUser> UserManager
@inject AutoPartsStore.Core.Interfaces.ICartItemRepository CartItemRepository
@{
    // Корзина есть и у гостей (по cookie), поэтому считаем количество
    // и для вошедших, и для анонимных пользователей.
    string? cartOwnerId = SignInManager.IsSignedIn(User)
        ? UserManager.GetUserId(User)
        : (Context.Request.Cookies.TryGetValue(CartConstants.GuestCookieName, out var guestCartId) ? guestCartId : null);

    var cartCount = cartOwnerId is not null
        ? await CartItemRepository.GetItemCountAsync(cartOwnerId)
        : 0;

    var headerBonusPoints = 0;
    if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        headerBonusPoints = currentUser?.BonusPoints ?? 0;
    }

    // Баннер про cookies показываем, пока пользователь его не подтвердил
    // (см. cookie "CookieConsent", выставляется в JS внизу страницы).
    var cookieConsentGiven = Context.Request.Cookies.ContainsKey("CookieConsent");
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MirBest</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav>
            <div class="nav-left">
                <a asp-controller="Home" asp-action="Index" class="brand">
                    <img src="~/images/logo.svg" alt="MIRBEST" class="site-logo" />
                </a>
            </div>
            <div class="nav-search">
                <form asp-controller="Products" asp-action="Index" method="get" class="search-form">
                    <input type="search" name="search" value="@ViewData["CurrentSearch"]" placeholder="Ersatzteile suchen..." class="search-input" />
                    <button type="submit" class="search-btn" aria-label="Suchen">
                        <partial name="_Icon" model="@("search")" />
                    </button>
                </form>
            </div>
            <button type="button" class="burger-btn" id="burgerBtn" aria-label="Menü öffnen" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <div class="nav-right" id="navRight">
                <a asp-controller="Cart" asp-action="Index" class="nav-icon-link" title="Warenkorb">
                    <partial name="_Icon" model="@("cart")" />
                    @if (cartCount > 0)
                    {
                        <span class="cart-badge">@cartCount</span>
                    }
                </a>
                @if (SignInManager.IsSignedIn(User))
                {
                    <a asp-controller="Orders" asp-action="Index" class="nav-icon-link" title="Meine Bestellungen">
                        <partial name="_Icon" model="@("list")" />
                        <span class="icon-label">Meine Bestellungen</span>
                    </a>
                    <span>Hallo, @User.Identity!.Name</span>
                    <span title="Bonuspunkte">Bonuspunkte: @headerBonusPoints</span>
                    <a asp-controller="Account" asp-action="ChangePassword" class="nav-icon-link" title="Passwort ändern">
                        <span class="icon-label">Passwort ändern</span>
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                        <button type="submit" class="btn btn-secondary icon-btn" title="Abmelden">
                            <partial name="_Icon" model="@("logout")" />
                            <span class="icon-label">Abmelden</span>
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="nav-icon-link" title="Anmelden">
                        <partial name="_Icon" model="@("user")" />
                        <span class="icon-label">Anmelden</span>
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="nav-icon-link" title="Registrieren">
                        <partial name="_Icon" model="@("user-plus")" />
                        <span class="icon-label">Registrieren</span>
                    </a>
                }
            </div>
        </nav>
    </header>
    <div class="container">
        @if (TempData["CartMessage"] != null)
        {
            <p class="alert-success">@TempData["CartMessage"]</p>
        }
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <footer>
        <div class="container footer-simple">
            <div class="footer-col">
                <h3>MIRBEST</h3>
                <p>Wir schaffen Lösungen für Ihren Erfolg</p>
            </div>
            <div class="footer-social">
                <a href="https://www.facebook.com/mirplusde" target="_blank" rel="noopener" class="icon-link" title="Facebook">
                    <partial name="_Icon" model="@("facebook")" />
                </a>
                <a href="https://www.instagram.com/mirbest.de/" target="_blank" rel="noopener" class="icon-link" title="Instagram">
                    <partial name="_Icon" model="@("instagram")" />
                </a>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container footer-bottom-inner">
                <span>&copy; 2026 MIRBEST Alle Rechte vorbehalten.</span>
                <span class="footer-legal-links">
                    <a asp-controller="Contact" asp-action="Index">Kontakt</a>
                    <a asp-controller="Legal" asp-action="Impressum">Impressum</a>
                    <a asp-controller="Legal" asp-action="Datenschutz">Datenschutz</a>
                </span>
            </div>
        </div>
    </footer>

    @if (!cookieConsentGiven)
    {
        <div id="cookie-banner" class="cookie-banner">
            <p>
                Diese Website verwendet ausschließlich technisch notwendige Cookies (z. B. für Warenkorb und Anmeldung).
                Es werden keine Tracking- oder Marketing-Cookies eingesetzt.
                <a asp-controller="Legal" asp-action="Datenschutz">Mehr erfahren</a>
            </p>
            <button type="button" id="cookie-banner-accept" class="btn">Verstanden</button>
        </div>
    }

    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
